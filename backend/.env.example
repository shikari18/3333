# ─── Django Core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use SQLite (dev). Set to a postgres:// URL for production.
DATABASE_URL=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-key-here
OPENROUTER_MODEL=openrouter/auto
GOOGLE_STUDIO_API_KEY=your-gemini-key-here

# ─── Storage (S3 / Cloudflare R2) ─────────────────────────────────────────────
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=        # For R2 or DigitalOcean Spaces
# AWS_S3_CUSTOM_DOMAIN=       # e.g. cdn.examglow.com

# ─── Redis (WebSockets / Background Tasks) ────────────────────────────────────
# Leave empty to use in-memory channel layer (dev only)
REDIS_URL=

# ─── Payments (Paystack) ──────────────────────────────────────────────────────
# PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=

# ─── GitHub Integration ───────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=jerry-courage/exam-glow
